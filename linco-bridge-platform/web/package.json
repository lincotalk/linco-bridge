{
  "name": "linco-bridge-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:h5": "uni",
    "build:h5": "node scripts/with-prod-env.mjs build && node scripts/verify-h5-tabbar.mjs",
    "dev:mp-weixin": "node scripts/with-prod-env.mjs local.env -p mp-weixin",
    "build:mp-weixin": "node scripts/with-prod-env.mjs build -p mp-weixin",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,json,css,scss}\" \"*.{ts,js,mjs,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,json,css,scss}\" \"*.{ts,js,mjs,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4070620250821001",
    "@dcloudio/uni-app-harmony": "3.0.0-4070620250821001",
    "@dcloudio/uni-app-plus": "3.0.0-4070620250821001",
    "@dcloudio/uni-components": "3.0.0-4070620250821001",
    "@dcloudio/uni-h5": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4070620250821001",
    "highlight.js": "^11.11.1",
    "pinia": "^3.0.3",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.4",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.16",
    "@dcloudio/uni-automator": "3.0.0-4070620250821001",
    "@dcloudio/uni-cli-shared": "3.0.0-4070620250821001",
    "@dcloudio/uni-stacktracey": "3.0.0-4070620250821001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4070620250821001",
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.28.0",
    "eslint-plugin-vue": "^10.1.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "sass": "^1.89.0",
    "sharp": "^0.35.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vite": "^5.2.8",
    "vitest": "^3.1.4",
    "vue-tsc": "^2.2.10"
  }
}
